# Application Settings
APP_NAME="Bhagavad Gita RAG API"
APP_VERSION="2.0.0"
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8080

# Paths
PDF_PATH=11-Bhagavad-gita_As_It_Is.pdf
VECTOR_STORE_PATH=data/vector_store
LOGS_PATH=logs

# Embedding Model
EMBEDDING_MODEL_NAME=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=32

# Chunking
CHUNK_SIZE=1200
CHUNK_OVERLAP=200

# Vector Store
VECTOR_TOP_K=5
SIMILARITY_THRESHOLD=0.7
USE_MMR=true
MMR_DIVERSITY_SCORE=0.3

# LLM Settings
LLM_PROVIDER=openai  # "openai" or "ollama"
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=1000

# Ollama Settings (if using local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# RAG Settings
MAX_CONTEXT_LENGTH=4000
INCLUDE_SOURCES=true
MIN_SOURCES=1
MAX_SOURCES=5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # "json" or "text"

# CORS Origins (comma-separated)
CORS_ORIGINS=https://mysupernews.web.app,http://localhost:3000,http://localhost:8000

# ============================================
# NOTIFICATION SETTINGS
# ============================================

# Enable/disable notifications
NOTIFICATIONS_ENABLED=false

# Notification channels (comma-separated: email,sms,whatsapp,slack,discord)
NOTIFICATION_CHANNELS=email

# Email Notifications (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
NOTIFICATION_EMAIL_FROM=noreply@gitagpt.com
NOTIFICATION_EMAIL_TO=your-email@example.com

# SMS Notifications (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+1234567890

# WhatsApp Notifications (Twilio WhatsApp)
WHATSAPP_FROM_NUMBER=whatsapp:+14155238886
WHATSAPP_TO_NUMBER=whatsapp:+15551234567

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord Notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL
