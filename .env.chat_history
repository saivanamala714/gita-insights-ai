# ============================================
# Firestore Chat History Configuration
# ============================================
# Add these variables to your .env file

# Firestore Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
FIRESTORE_DATABASE_ID=(default)
FIRESTORE_COLLECTION_PREFIX=prod  # Use 'dev' for development, 'prod' for production

# Admin Authentication
# Generate a secure API key using: python scripts/generate_admin_key.py
ADMIN_API_KEY=your-secure-admin-key-here
ADMIN_USERNAME=admin
# Generate password hash using: python scripts/generate_admin_key.py --password yourpassword
ADMIN_PASSWORD_HASH=your-hashed-password-here

# Chat History Settings
MAX_CONVERSATION_HISTORY=50
CONVERSATION_CONTEXT_SIZE=10
AUTO_ARCHIVE_DAYS=90
SESSION_TIMEOUT_MINUTES=60

# Analytics
ENABLE_ANALYTICS=true
ANALYTICS_UPDATE_INTERVAL=3600  # 1 hour in seconds

# ============================================
# Instructions:
# ============================================
# 1. Copy these variables to your .env file
# 2. Replace 'your-gcp-project-id' with your actual GCP project ID
# 3. Generate admin credentials using the script:
#    python scripts/generate_admin_key.py
# 4. Update ADMIN_API_KEY and ADMIN_PASSWORD_HASH with generated values
